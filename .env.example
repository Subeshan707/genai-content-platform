# ─────────────────────────────────────────────────
# GenAI Content Creation Platform — Environment Vars
# Copy to .env and fill in real values
# ─────────────────────────────────────────────────

# ── AWS ──────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=AKIATCKD3QFHPW3AXQQ4
AWS_SECRET_ACCESS_KEY=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
AWS_SESSION_TOKEN=

# ── Bedrock ──────────────────────────────────────
BEDROCK_TEXT_MODEL_ID=amazon.nova-micro-v1:0
BEDROCK_TEXT_LITE_MODEL_ID=amazon.nova-micro-v1:0
BEDROCK_EMBED_MODEL_ID=amazon.titan-embed-text-v2:0
BEDROCK_IMAGE_MODEL_ID=amazon.titan-image-generator-v2:0
BEDROCK_GUARDRAIL_ID=

# ── PostgreSQL (Aurora-compatible) ───────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=genai_platform
POSTGRES_USER=genai_admin
POSTGRES_PASSWORD=changeme_postgres_password

# ── MongoDB (DocumentDB-compatible) ─────────────
MONGO_HOST=mongo
MONGO_PORT=27017
MONGO_DB=genai_locales
MONGO_USER=genai_admin
MONGO_PASSWORD=changeme_mongo_password
MONGO_INITDB_ROOT_USERNAME=genai_admin
MONGO_INITDB_ROOT_PASSWORD=changeme_mongo_password

# ── Redis (ElastiCache-compatible) ───────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=changeme_redis_password

# ── FastAPI AI Service ───────────────────────────
AI_SERVICE_HOST=0.0.0.0
AI_SERVICE_PORT=8000
AI_SERVICE_LOG_LEVEL=info

# ── Spring Boot Core Service ────────────────────
CORE_SERVICE_PORT=8080
SPRING_PROFILES_ACTIVE=local

# ── Cognito (local dev uses mock) ────────────────
COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
COGNITO_REGION=us-east-1

# ── API Gateway WebSocket ────────────────────────
WEBSOCKET_API_ID=xxxxxxxxxx
WEBSOCKET_API_STAGE=prod
WEBSOCKET_ENDPOINT=ws://localhost:8000/ws

# ── SQS Queues (LocalStack) ─────────────────────
SQS_ENDPOINT=http://localstack:4566
SQS_CONTENT_INGEST_QUEUE=content-ingest.fifo
SQS_LOCALIZE_QUEUE=localize.fifo
SQS_IMAGE_GENERATE_QUEUE=image-generate
SQS_CMS_PUBLISH_QUEUE=cms-publish.fifo

# ── S3 Buckets (LocalStack) ─────────────────────
S3_ENDPOINT=http://localstack:4566
S3_BRAND_DOCS_BUCKET=genai-brand-docs
S3_MEDIA_ASSETS_BUCKET=genai-media-assets
S3_MODEL_LOGS_BUCKET=genai-model-logs

# ── CMS Integrations ────────────────────────────
CONTENTFUL_SPACE_ID=
CONTENTFUL_MGMT_TOKEN=
STRAPI_URL=
STRAPI_API_TOKEN=
WP_URL=
WP_USER=
WP_APP_PASSWORD=

# ── Observability ───────────────────────────────
XRAY_DAEMON_ADDRESS=xray:2000
CLOUDWATCH_NAMESPACE=genai-content-platform
ENABLE_XRAY=false
LOG_LEVEL=INFO
